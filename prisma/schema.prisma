generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  PROJECT_MANAGER
  OFFICE
  FOREMAN
  EMPLOYEE
  CONTRACTOR
  CLIENT
}

enum RecordStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum ProjectStatus {
  BUDGET
  PLANNING
  IN_PROGRESS
  PAUSED
  WAITING_CLIENT
  WAITING_MATERIAL
  WAITING_CONTRACTOR
  INSPECTION
  COMPLETED
  CANCELED
}

enum ProjectPriority {
  HIGH
  MEDIUM
  LOW
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  PAUSED
  BLOCKED
  WAITING_MATERIAL
  WAITING_APPROVAL
  COMPLETED
  REJECTED
  CANCELED
}

enum PurchaseStatus {
  REQUESTED
  QUOTING
  WAITING_APPROVAL
  APPROVED
  PURCHASED
  RECEIVED
  CANCELED
  REJECTED
}

enum StockMovementType {
  PURCHASE_ENTRY
  TRANSFER_ENTRY
  CONSUMPTION
  DISPOSAL
  LOSS
  RETURN_TO_CENTRAL
}

enum DisposalStatus {
  REQUESTED
  SCHEDULED
  REMOVED
  PROVED
  CANCELED
}

enum FinancialStatus {
  OPEN
  PAID
  OVERDUE
  CANCELED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELED
}

enum AllocationStatus {
  PLANNED
  ACTIVE
  PAUSED
  FINISHED
  CANCELED
}

enum DailyAttendanceStatus {
  PRESENT
  PARTIAL
  ABSENT
  TRANSFERRED
}

model User {
  id                     String             @id @default(cuid())
  name                   String
  email                  String             @unique
  passwordHash           String
  role                   UserRole
  phone                  String?
  status                 RecordStatus       @default(ACTIVE)
  managedProjects        Project[]          @relation("ProjectManager")
  technicalProjects      Project[]          @relation("TechnicalResponsible")
  responsibleAreas       ProjectArea[]      @relation("AreaResponsible")
  assignedTasks          Task[]             @relation("TaskAssignedUser")
  completedChecklist     TaskChecklistItem[] @relation("ChecklistCompletedBy")
  requestedPurchases     PurchaseRequest[]  @relation("PurchaseRequester")
  approvedPurchases      PurchaseRequest[]  @relation("PurchaseApprover")
  stockMovements         StockMovement[]
  wasteDisposals         WasteDisposal[]
  dailyReports           DailyReport[]      @relation("DailyReportCreator")
  validatedDailyReports  DailyReport[]      @relation("DailyReportValidator")
  uploadedFiles          File[]
  financialEntries       FinancialEntry[]
  requestedApprovals     Approval[]         @relation("ApprovalRequester")
  approvedApprovals      Approval[]         @relation("ApprovalApprover")
  auditLogs              AuditLog[]
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  @@index([role])
  @@index([status])
}

model Client {
  id             String       @id @default(cuid())
  name           String
  documentType   String?
  documentNumber String?
  phone          String?
  whatsapp       String?
  email          String?
  address        String?
  clientType     String
  notes          String?
  status         RecordStatus @default(ACTIVE)
  projects       Project[]
  files          File[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([name])
  @@index([documentNumber])
  @@index([status])
}

model Project {
  id                       String              @id @default(cuid())
  code                     String              @unique
  name                     String
  clientId                 String
  client                   Client              @relation(fields: [clientId], references: [id])
  projectType              String
  address                  String
  managerId                String?
  manager                  User?               @relation("ProjectManager", fields: [managerId], references: [id])
  technicalResponsibleId   String?
  technicalResponsible     User?               @relation("TechnicalResponsible", fields: [technicalResponsibleId], references: [id])
  plannedStartDate         DateTime?
  plannedEndDate           DateTime?
  actualStartDate          DateTime?
  actualEndDate            DateTime?
  plannedBudget            Decimal             @default(0) @db.Decimal(14, 2)
  actualCost               Decimal             @default(0) @db.Decimal(14, 2)
  status                   ProjectStatus        @default(PLANNING)
  priority                 ProjectPriority      @default(MEDIUM)
  notes                    String?
  employeeAllocations      ProjectEmployeeAllocation[]
  areas                    ProjectArea[]
  tasks                    Task[]
  projectContractors       ProjectContractor[]
  purchaseRequests         PurchaseRequest[]
  stockMovements           StockMovement[]      @relation("ProjectStockMovements")
  sourceTransfers          StockMovement[]      @relation("SourceProject")
  destinationTransfers     StockMovement[]      @relation("DestinationProject")
  attendanceTransfers      DailyReportAttendance[] @relation("DailyAttendanceTransferDestination")
  wasteDisposals           WasteDisposal[]
  dailyReports             DailyReport[]
  files                    File[]
  financialEntries         FinancialEntry[]
  createdAt                DateTime             @default(now())
  updatedAt                DateTime             @updatedAt

  @@index([clientId])
  @@index([managerId])
  @@index([status])
  @@index([priority])
}

model ProjectArea {
  id              String       @id @default(cuid())
  projectId       String
  project         Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  approximateArea Decimal?     @db.Decimal(10, 2)
  status          String       @default("PLANNING")
  responsibleId   String?
  responsible     User?        @relation("AreaResponsible", fields: [responsibleId], references: [id])
  tasks           Task[]
  files           File[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([projectId, name])
  @@index([projectId])
  @@index([responsibleId])
}

model Task {
  id                     String              @id @default(cuid())
  projectId              String
  project                Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  areaId                 String?
  area                   ProjectArea?        @relation(fields: [areaId], references: [id])
  title                  String
  description            String?
  serviceType            String
  assignedToUserId       String?
  assignedToUser         User?               @relation("TaskAssignedUser", fields: [assignedToUserId], references: [id])
  assignedToContractorId String?
  assignedToContractor   Contractor?         @relation("TaskAssignedContractor", fields: [assignedToContractorId], references: [id])
  plannedStartDate       DateTime?
  plannedEndDate         DateTime?
  actualStartDate        DateTime?
  actualEndDate          DateTime?
  status                 TaskStatus          @default(TODO)
  priority               ProjectPriority     @default(MEDIUM)
  blockedReason          String?
  checklistItems         TaskChecklistItem[]
  files                  File[]
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  @@index([projectId])
  @@index([areaId])
  @@index([status])
  @@index([plannedEndDate])
  @@index([assignedToUserId])
  @@index([assignedToContractorId])
}

model TaskChecklistItem {
  id            String    @id @default(cuid())
  taskId        String
  task          Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  title         String
  isCompleted   Boolean   @default(false)
  completedAt   DateTime?
  completedById String?
  completedBy   User?     @relation("ChecklistCompletedBy", fields: [completedById], references: [id])
  createdAt     DateTime  @default(now())

  @@index([taskId])
}

model Employee {
  id             String           @id @default(cuid())
  name           String
  documentNumber String?
  phone          String?
  jobTitle       String
  specialty      String?
  employmentType String?
  dailyRate      Decimal?         @db.Decimal(12, 2)
  salary         Decimal?         @db.Decimal(12, 2)
  status         RecordStatus     @default(ACTIVE)
  notes          String?
  projectAllocations ProjectEmployeeAllocation[]
  dailyAttendances DailyReportAttendance[]
  financialEntries FinancialEntry[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([name])
  @@index([status])
}

model Contractor {
  id                 String              @id @default(cuid())
  name               String
  documentNumber     String?
  contactName        String?
  phone              String?
  email              String?
  specialty          String?
  status             RecordStatus        @default(ACTIVE)
  rating             Int?
  notes              String?
  projectContracts   ProjectContractor[]
  assignedTasks      Task[]              @relation("TaskAssignedContractor")
  files              File[]
  financialEntries   FinancialEntry[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([name])
  @@index([specialty])
  @@index([status])
}

model ProjectContractor {
  id                 String       @id @default(cuid())
  projectId          String
  project            Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contractorId       String
  contractor         Contractor   @relation(fields: [contractorId], references: [id])
  serviceDescription String
  contractedValue    Decimal      @default(0) @db.Decimal(14, 2)
  startDate          DateTime?
  endDate            DateTime?
  status             String       @default("PLANNED")
  paymentTerms       String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@index([projectId])
  @@index([contractorId])
}

model ProjectEmployeeAllocation {
  id                 String           @id @default(cuid())
  projectId          String
  project            Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  employeeId         String
  employee           Employee         @relation(fields: [employeeId], references: [id])
  role               String
  serviceDescription String?
  startDate          DateTime
  endDate            DateTime?
  dailyRate          Decimal?         @db.Decimal(12, 2)
  status             AllocationStatus @default(ACTIVE)
  notes              String?
  attendances        DailyReportAttendance[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([projectId])
  @@index([employeeId])
  @@index([status])
  @@index([startDate])
}

model Supplier {
  id                   String                @id @default(cuid())
  name                 String
  documentNumber       String?
  contactName          String?
  phone                String?
  email                String?
  category             String?
  address              String?
  status               RecordStatus          @default(ACTIVE)
  notes                String?
  preferredMaterials   Material[]
  purchaseItems        PurchaseRequestItem[]
  files                File[]
  financialEntries     FinancialEntry[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@index([name])
  @@index([category])
  @@index([status])
}

model Material {
  id                  String                @id @default(cuid())
  name                String
  category            String
  unit                String
  brand               String?
  internalCode        String?               @unique
  preferredSupplierId String?
  preferredSupplier   Supplier?             @relation(fields: [preferredSupplierId], references: [id])
  averagePrice        Decimal?              @db.Decimal(12, 2)
  minimumStock        Decimal?              @db.Decimal(12, 3)
  notes               String?
  purchaseItems       PurchaseRequestItem[]
  stockMovements      StockMovement[]
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  @@index([name])
  @@index([category])
  @@index([preferredSupplierId])
}

model PurchaseRequest {
  id             String                @id @default(cuid())
  projectId      String
  project        Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requestedById  String
  requestedBy    User                  @relation("PurchaseRequester", fields: [requestedById], references: [id])
  status         PurchaseStatus        @default(REQUESTED)
  urgency        String?
  neededBy       DateTime?
  justification  String?
  estimatedTotal Decimal?              @db.Decimal(14, 2)
  approvedTotal  Decimal?              @db.Decimal(14, 2)
  approvedById   String?
  approvedBy     User?                 @relation("PurchaseApprover", fields: [approvedById], references: [id])
  approvedAt     DateTime?
  notes          String?
  items          PurchaseRequestItem[]
  stockMovements StockMovement[]
  financialEntries FinancialEntry[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([projectId])
  @@index([requestedById])
  @@index([approvedById])
  @@index([status])
}

model PurchaseRequestItem {
  id                  String          @id @default(cuid())
  purchaseRequestId   String
  purchaseRequest     PurchaseRequest @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)
  materialId          String?
  material            Material?       @relation(fields: [materialId], references: [id])
  description         String?
  quantity            Decimal         @db.Decimal(12, 3)
  unit                String
  estimatedUnitPrice  Decimal?        @db.Decimal(12, 2)
  approvedUnitPrice   Decimal?        @db.Decimal(12, 2)
  supplierId          String?
  supplier            Supplier?       @relation(fields: [supplierId], references: [id])
  createdAt           DateTime        @default(now())

  @@index([purchaseRequestId])
  @@index([materialId])
  @@index([supplierId])
}

model StockMovement {
  id                 String            @id @default(cuid())
  projectId          String
  project            Project           @relation("ProjectStockMovements", fields: [projectId], references: [id], onDelete: Cascade)
  materialId         String
  material           Material          @relation(fields: [materialId], references: [id])
  movementType       StockMovementType
  quantity           Decimal           @db.Decimal(12, 3)
  unit               String
  unitCost           Decimal?          @db.Decimal(12, 2)
  totalCost          Decimal?          @db.Decimal(14, 2)
  sourceProjectId    String?
  sourceProject      Project?          @relation("SourceProject", fields: [sourceProjectId], references: [id])
  destinationProjectId String?
  destinationProject Project?          @relation("DestinationProject", fields: [destinationProjectId], references: [id])
  purchaseRequestId  String?
  purchaseRequest    PurchaseRequest?  @relation(fields: [purchaseRequestId], references: [id])
  notes              String?
  createdById        String
  createdBy          User              @relation(fields: [createdById], references: [id])
  createdAt          DateTime          @default(now())

  @@index([projectId])
  @@index([materialId])
  @@index([movementType])
  @@index([createdAt])
}

model WasteDisposal {
  id                String         @id @default(cuid())
  projectId         String
  project           Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  wasteType         String
  estimatedVolume   Decimal?       @db.Decimal(12, 3)
  unit              String?
  disposalCompanyId String?
  scheduledDate     DateTime?
  removedAt         DateTime?
  cost              Decimal?       @db.Decimal(14, 2)
  status            DisposalStatus @default(REQUESTED)
  proofFileId       String?        @unique
  proofFile         File?          @relation("DisposalProof", fields: [proofFileId], references: [id])
  notes             String?
  createdById       String
  createdBy         User           @relation(fields: [createdById], references: [id])
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([projectId])
  @@index([status])
  @@index([scheduledDate])
}

model DailyReport {
  id                  String    @id @default(cuid())
  projectId           String
  project             Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reportDate          DateTime
  createdById         String
  createdBy           User      @relation("DailyReportCreator", fields: [createdById], references: [id])
  teamNotes           String?
  servicesExecuted    String?
  materialsReceived   String?
  materialsUsed       String?
  occurrences         String?
  issues              String?
  pendingItems        String?
  weatherNotes        String?
  validatedById       String?
  validatedBy         User?     @relation("DailyReportValidator", fields: [validatedById], references: [id])
  validatedAt         DateTime?
  attendances         DailyReportAttendance[]
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([projectId, reportDate])
  @@index([projectId])
  @@index([createdById])
}

model DailyReportAttendance {
  id                   String                @id @default(cuid())
  dailyReportId        String
  dailyReport          DailyReport           @relation(fields: [dailyReportId], references: [id], onDelete: Cascade)
  employeeId           String
  employee             Employee              @relation(fields: [employeeId], references: [id])
  allocationId         String?
  allocation           ProjectEmployeeAllocation? @relation(fields: [allocationId], references: [id])
  status               DailyAttendanceStatus @default(PRESENT)
  hoursWorked          Decimal?              @db.Decimal(5, 2)
  transferredToProjectId String?
  transferredToProject Project?              @relation("DailyAttendanceTransferDestination", fields: [transferredToProjectId], references: [id])
  notes                String?
  createdAt            DateTime              @default(now())

  @@unique([dailyReportId, employeeId])
  @@index([dailyReportId])
  @@index([employeeId])
  @@index([allocationId])
  @@index([transferredToProjectId])
}

model File {
  id              String          @id @default(cuid())
  projectId       String?
  project         Project?        @relation(fields: [projectId], references: [id])
  areaId          String?
  area            ProjectArea?    @relation(fields: [areaId], references: [id])
  taskId          String?
  task            Task?           @relation(fields: [taskId], references: [id])
  clientId        String?
  client          Client?         @relation(fields: [clientId], references: [id])
  contractorId    String?
  contractor      Contractor?     @relation(fields: [contractorId], references: [id])
  supplierId      String?
  supplier        Supplier?       @relation(fields: [supplierId], references: [id])
  fileType        String
  category        String?
  fileName        String
  fileUrl         String
  mimeType        String
  size            Int
  uploadedById    String
  uploadedBy      User            @relation(fields: [uploadedById], references: [id])
  disposalProofOf WasteDisposal?  @relation("DisposalProof")
  financialEntries FinancialEntry[] @relation("FinancialDocument")
  createdAt       DateTime        @default(now())

  @@index([projectId])
  @@index([areaId])
  @@index([taskId])
  @@index([clientId])
  @@index([fileType])
}

model FinancialEntry {
  id                String          @id @default(cuid())
  projectId         String
  project           Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  entryType         String
  category          String
  description       String
  amount            Decimal         @db.Decimal(14, 2)
  dueDate           DateTime?
  paidAt            DateTime?
  status            FinancialStatus @default(OPEN)
  supplierId        String?
  supplier          Supplier?       @relation(fields: [supplierId], references: [id])
  contractorId      String?
  contractor        Contractor?     @relation(fields: [contractorId], references: [id])
  employeeId        String?
  employee          Employee?       @relation(fields: [employeeId], references: [id])
  purchaseRequestId String?
  purchaseRequest   PurchaseRequest? @relation(fields: [purchaseRequestId], references: [id])
  documentFileId    String?
  documentFile      File?           @relation("FinancialDocument", fields: [documentFileId], references: [id])
  createdById       String
  createdBy         User            @relation(fields: [createdById], references: [id])
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([projectId])
  @@index([category])
  @@index([status])
  @@index([dueDate])
}

model Approval {
  id            String         @id @default(cuid())
  approvalType  String
  referenceId   String
  requestedById String
  requestedBy   User           @relation("ApprovalRequester", fields: [requestedById], references: [id])
  approvedById  String?
  approvedBy    User?          @relation("ApprovalApprover", fields: [approvedById], references: [id])
  status        ApprovalStatus @default(PENDING)
  justification String?
  responseNotes String?
  requestedAt   DateTime       @default(now())
  respondedAt   DateTime?

  @@index([approvalType, referenceId])
  @@index([requestedById])
  @@index([approvedById])
  @@index([status])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  entityType String
  entityId   String
  action     String
  oldData    Json?
  newData    Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}
